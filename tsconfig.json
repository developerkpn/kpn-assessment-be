{
  "compilerOptions": {
    "target": "es6",
    "jsx": "react-jsx",
    "module": "nodenext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@/*": ["./*"]
    },
    "moduleResolution": "nodenext",
    "outDir": "./dist",
    "typeRoots": [
      "./types"
    ]
  },
  "include": [
    "./**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ],
  "skipLibCheck": true /* Skip type checking all .d.ts files. */
}