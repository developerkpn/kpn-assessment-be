{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strict": true,
    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": ".",
    "jsx" : "react",
    "paths": {
      "@/*": ["./*"]
    }
  },
"include": ["**/*.ts", "**/*.tsx", "./assets"],
  "exclude": ["node_modules", "dist"]
}